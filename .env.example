# ══════════════════════════════════════════════════════════════
#  Polymarket Sniper Bot v5.0 — Configuration
# ══════════════════════════════════════════════════════════════
#  Copy this file:  cp .env.example .env
#  Then fill in your credentials below.
# ══════════════════════════════════════════════════════════════

# ── Polymarket Wallet ────────────────────────────────────────
# Export from: polymarket.com > Cash > ⋯ > Export Private Key
PRIVATE_KEY=your_private_key_here
WALLET_ADDRESS=your_wallet_address_here

# Signature type: 0 = EOA wallet, 1 = Polymarket email/Magic wallet
SIGNATURE_TYPE=1

# ── VPN (Required) ──────────────────────────────────────────
# Bot checks VPN before every trade cycle. Must be non-US IP.
# Install ProtonVPN or any VPN, connect to a non-US server.
PROTON_VPN_REQUIRED=true

# ── Telegram Alerts (Optional) ──────────────────────────────
# Get alerts on your phone for every trade, win, and loss.
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message @userinfobot → copy your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Telegram Control Bot (Optional) ─────────────────────────
# Control the bot from your phone using Claude AI.
# Message your bot in natural language — Claude reads logs,
# edits code, restarts services, and diagnoses issues.
# Sign up at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Allium On-Chain Data (Optional) ─────────────────────────
# Provides smart money tracking + flow imbalance signals.
# Sign up at: https://app.allium.so → API Keys
# Bot works fine without this — signals are supplementary.
ALLIUM_API_KEY=

# ══════════════════════════════════════════════════════════════
#  Weather Bracket Bot (python bot.py bracket)
#  Uses GFS 31-member ensemble for probability
# ══════════════════════════════════════════════════════════════

# Edge threshold — only trade when ensemble edge > this (0.08 = 8%)
V4_MIN_EDGE_WEATHER=0.08

# Scan interval in seconds (300 = every 5 minutes)
V4_SCAN_INTERVAL=300

# Bet sizing
V4_MAX_BET=10.0         # Max bet per trade (USDC)
V4_MIN_BET=2.0          # Min bet per trade (USDC)
V4_DAILY_BANKROLL=50.0  # Total daily budget (USDC)

# Kelly criterion fraction (0.10 = 10% Kelly — conservative)
V4_KELLY_FRACTION=0.10

# Max price to enter a position (0.80 = won't buy above 80 cents)
V4_MAX_ENTRY_PRICE=0.80

# Win probability filter — only bet when model says ≥65% chance
V4_MIN_WIN_PROB=0.65

# Max share price — cheap shares have better risk/reward
V4_MAX_BUY_PRICE=0.50

# Max bets per scan cycle
V4_MAX_WEATHER_PER_CYCLE=6

# Max open positions at any time
V4_MAX_OPEN_POSITIONS=6

# Skip markets resolving in less than 6 hours
V4_MIN_HOURS_TO_RESOLUTION=6.0

# Model vs market sanity check — skip if they disagree by >40%
V4_MAX_MODEL_MARKET_DISAGREE=0.40

# ══════════════════════════════════════════════════════════════
#  Crypto Maker Bot (python bot.py maker)
#  15-min BTC/ETH/SOL up/down — GTC maker orders near close
# ══════════════════════════════════════════════════════════════

# Which coins to trade (comma-separated)
MAKER_COINS=BTC,ETH,SOL

# Bet sizing
MAKER_BET_SIZE=5.0          # Default bet per trade (USDC)
MAKER_MAX_BET=10.0          # Max bet per trade (USDC)
MAKER_DAILY_BANKROLL=50.0   # Total daily budget (USDC)
MAKER_DAILY_LOSS_LIMIT=25.0 # Stop trading after $25 in losses

# Direction detection — min price move to trigger a bet
MAKER_MIN_MOVE_PCT=0.10     # 0.1% — lower = more trades, higher = more selective

# Bid pricing — scales with confidence (bigger move = higher bid)
MAKER_BID_PRICE_LOW=0.88    # Bid for small moves (0.1%)
MAKER_BID_PRICE_HIGH=0.95   # Bid for large moves (0.5%+)

# Timing — how many seconds before window close to enter
# 480 = 8 minutes (gives orders plenty of time to fill, Allium filter catches bad calls)
MAKER_ENTRY_SECONDS=480

# Risk management
MAKER_LOSS_STREAK_LIMIT=3   # Pause after 3 consecutive losses
MAKER_LOSS_COOLDOWN=3600    # Cooldown duration in seconds (3600 = 1 hour)

# ══════════════════════════════════════════════════════════════
#  V6 Multi-Strategy Engine (python bot.py v6)
#  Runs 3 strategies: Hedge + Market Making + Late Entry
# ══════════════════════════════════════════════════════════════

# Coins to trade
V6_COINS=BTC,ETH

# Bankroll and risk
V6_BANKROLL=100.0
V6_DAILY_LOSS_LIMIT=40.0

# Paper trade mode (true = simulate, false = real money)
PAPER_TRADE=true

# Enable/disable individual strategies
V6_HEDGE_ENABLED=true
V6_MM_ENABLED=true
V6_LATE_ENABLED=true

# Bankroll allocation (must sum to 1.0)
V6_HEDGE_ALLOC=0.50
V6_MM_ALLOC=0.30
V6_LATE_ALLOC=0.20

# Hedge — buy both sides when UP+DOWN ask < threshold
V6_HEDGE_THRESHOLD=0.98
V6_HEDGE_BET_SIZE=5.0

# Market Making — capture spread + maker rebates
V6_MM_SPREAD=0.02
V6_MM_SIZE=5.0
V6_MM_MAX_INVENTORY=20.0

# Late Entry — whale-confirmed directional at T-120s
V6_LATE_ENTRY_SECONDS=120
V6_LATE_MIN_MOVE_PCT=0.30
V6_LATE_BID_LOW=0.93
V6_LATE_BID_HIGH=0.95
V6_LATE_BET_SIZE=5.0
V6_LATE_REQUIRE_ALLIUM=true

# ══════════════════════════════════════════════════════════════
#  AI Mispricing Scanner (python bot.py aiscan)
#  Uses Exa deep reasoning to find mispriced markets
# ══════════════════════════════════════════════════════════════

# Exa API — deep reasoning search for probability estimation
# Sign up at: https://exa.ai → API Keys
EXA_API_KEY=

# Bet sizing — scales with edge (bigger edge = bigger bet)
AI_BET_SIZE_MIN=2.50        # Min bet (10% edge)
AI_BET_SIZE_MAX=5.00        # Max bet (30%+ edge)

# Edge threshold — only trade when AI vs market disagrees by this much
AI_MIN_EDGE=0.10            # 10 points minimum

# Market filters
AI_MAX_MARKETS=20           # Markets to analyze per scan
AI_MIN_PROB=0.30            # Only scan 30-70% probability markets
AI_MAX_PROB=0.70
AI_MIN_VOLUME=1000          # $1k+ 24h volume
AI_MAX_RESOLUTION_DAYS=30   # Resolve within 30 days
AI_SCAN_INTERVAL_HOURS=24   # Auto-scan interval

# ══════════════════════════════════════════════════════════════
#  Bond Grinder (python bot.py bonds)
#  Near-certainty yield strategy (85-99% outcomes)
# ══════════════════════════════════════════════════════════════

BOND_BUDGET=0               # Daily budget (0 = unlimited)
BOND_BET_SIZE=2.0           # Per position
BOND_MIN_PRICE=0.95         # Only 95+ cents
BOND_MAX_PRICE=0.993        # Leave room for fees
BOND_MIN_HOURS=2.0          # Not too close to expiry
BOND_MAX_DAYS=7.0           # Up to 7 days
BOND_MIN_VOLUME=100         # $100+ 24h volume
BOND_MAX_POSITIONS=10       # Max simultaneous
BOND_MIN_YIELD=0.005        # Min 0.5% yield
BOND_SCAN_INTERVAL=300      # Scan every 5 min
BOND_USE_ALLIUM=true        # Smart money gate

# ══════════════════════════════════════════════════════════════
#  v1 Sniper Bot Config (python bot.py scan / run)
# ══════════════════════════════════════════════════════════════

# Price filter: only buy outcomes in this range
MIN_PRICE=0.005         # 0.5 cents — filters out dead markets
MAX_PRICE=0.03          # 3 cents — max price to buy

# Bet sizing
BET_SIZE_USDC=10        # USDC per bet
MAX_DAILY_SPEND=100     # Daily spending cap

# Scan interval
SCAN_INTERVAL_MINUTES=30
