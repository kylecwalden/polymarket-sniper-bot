# Polymarket Wallet
# Export from: polymarket.com > Cash > ⋯ > Export Private Key
PRIVATE_KEY=your_private_key_here
WALLET_ADDRESS=your_wallet_address_here

# Signature type: 0=EOA wallet, 1=Polymarket email/Magic wallet
SIGNATURE_TYPE=1

# Bot Configuration
MIN_PRICE=0.005         # Minimum price to buy (0.005 = 0.5 cents) — filters out dead markets
MAX_PRICE=0.03          # Maximum price to buy (0.03 = 3 cents)
BET_SIZE_USDC=10        # USDC per bet
MAX_DAILY_SPEND=100     # Max USDC to spend per day
SCAN_INTERVAL_MINUTES=30 # How often to scan for new markets

# ProtonVPN
# The bot will check VPN is active before trading
PROTON_VPN_REQUIRED=true
